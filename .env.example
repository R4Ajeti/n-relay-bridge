# Firebase Web config encoded as base64 JSON.
# This is client web config, not a Firebase service-account private key.
#
# Required JSON shape before encoding:
# {
#   "apiKey": "AIza...",
#   "authDomain": "your-project.firebaseapp.com",
#   "databaseURL": "https://your-project-default-rtdb.firebaseio.com",
#   "projectId": "your-project",
#   "appId": "1:000000000000:web:0000000000000000000000"
# }
#
# Example:
# printf '%s' '{"apiKey":"AIza...","authDomain":"your-project.firebaseapp.com","databaseURL":"https://your-project-default-rtdb.firebaseio.com","projectId":"your-project","appId":"1:000000000000:web:0000000000000000000000"}' | base64
N_RELAY_FIREBASE_WEB_CONFIG_BASE64=

# Optional: override where the generated browser config is written.
# N_RELAY_FIREBASE_CONFIG_OUTPUT=src/firebase-config.generated.json
