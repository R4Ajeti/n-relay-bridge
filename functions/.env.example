# Firebase Functions runtime environment for Web Push.
# Copy to functions/.env for local/deploy use; do not commit the real private key.
#
# Generate keys with:
# npm run functions:install
# npm run webpush:keys

N_RELAY_WEB_PUSH_PUBLIC_KEY=
N_RELAY_WEB_PUSH_PRIVATE_KEY=
N_RELAY_WEB_PUSH_SUBJECT=mailto:admin@example.com
