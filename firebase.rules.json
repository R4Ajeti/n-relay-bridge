{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "messageRequests": {
          ".indexOn": ["status", "targetDeviceId", "createdAt"]
        },
        "devices": {
          ".indexOn": ["platform", "role", "trusted"]
        }
      }
    }
  }
}
